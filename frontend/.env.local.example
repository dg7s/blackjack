# .env.local.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local — it is listed in .gitignore and never committed.
# VITE_* variables are inlined at build time; never store secrets here.
#
# ── Local development (recommended) ──────────────────────────────────────────
# Leave VITE_API_BASE_URL empty.  Vite's dev proxy (vite.config.ts) forwards:
#   /api/** → Django :8000
#   /sse/** → Django :8000
# This is the zero-friction setup — no CORS to configure, no origin mismatch.

VITE_API_BASE_URL=

# ── Bypass the Vite proxy ─────────────────────────────────────────────────────
# Uncomment if you want axios and EventSource to hit Django directly.
# Django's CORS_ALLOWED_ORIGINS must include http://localhost:5173.
#
# VITE_API_BASE_URL=http://localhost:8000

# ── Production (Render.com, same-domain deployment) ───────────────────────────
# If the React build is served from the same Render service as Django,
# keep this empty — relative paths work out of the box.
#
# If frontend and backend are on SEPARATE Render services:
# VITE_API_BASE_URL=https://your-api.onrender.com
